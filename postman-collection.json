{
  "info": {
    "name": "C Origen — Microservicios",
    "_postman_id": "corigenms-2026",
    "description": "Colección completa para ProyectoGrupal UPEU. Gateway: localhost:7091",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE", "value": "http://localhost:7091", "type": "string" },
    { "key": "TOKEN", "value": "", "type": "string" },
    { "key": "KEYCLOAK", "value": "http://localhost:8080", "type": "string" }
  ],
  "item": [

    {
      "name": "🔐 Auth — Keycloak",
      "item": [
        {
          "name": "Login ADMIN (obtener token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.access_token) {",
                  "  pm.collectionVariables.set('TOKEN', res.access_token);",
                  "  console.log('Token guardado correctamente');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "url": { "raw": "{{KEYCLOAK}}/realms/upeu/protocol/openid-connect/token", "host": ["{{KEYCLOAK}}"], "path": ["realms","upeu","protocol","openid-connect","token"] },
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "password" },
                { "key": "client_id",  "value": "microservices-app" },
                { "key": "username",   "value": "admin" },
                { "key": "password",   "value": "admin123" }
              ]
            }
          }
        },
        {
          "name": "Login USER (obtener token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.access_token) {",
                  "  pm.collectionVariables.set('TOKEN', res.access_token);",
                  "  console.log('Token guardado correctamente');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "url": { "raw": "{{KEYCLOAK}}/realms/upeu/protocol/openid-connect/token", "host": ["{{KEYCLOAK}}"], "path": ["realms","upeu","protocol","openid-connect","token"] },
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "password" },
                { "key": "client_id",  "value": "microservices-app" },
                { "key": "username",   "value": "user" },
                { "key": "password",   "value": "user123" }
              ]
            }
          }
        }
      ]
    },

