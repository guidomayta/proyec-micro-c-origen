          }
        },
        {
          "name": "Eliminar producto",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }],
            "url": { "raw": "{{BASE}}/api/v1/productos/1", "host": ["{{BASE}}"], "path": ["api","v1","productos","1"] }
          }
        },
