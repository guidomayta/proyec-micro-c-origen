            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Laptop Dell XPS (actualizado)\",\n  \"descripcion\": \"Intel i9, 32GB RAM\",\n  \"precio\": 4200.00,\n  \"stock\": 5,\n  \"categoria\": \"Electrónica\"\n}"
            }
